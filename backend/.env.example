# Backend environment variables
# Port used by the Express server.
PORT=5000

# MySQL host, normally 127.0.0.1 for XAMPP.
MYSQL_HOST=127.0.0.1

# MySQL port, normally 3306.
MYSQL_PORT=3306

# MySQL username.
MYSQL_USER=root

# MySQL password. XAMPP often uses an empty password locally.
MYSQL_PASSWORD=

# Database name shown in phpMyAdmin.
MYSQL_DATABASE=dashboard_app

# Frontend origin allowed by CORS. Separate multiple values with commas.
CLIENT_URL=http://localhost:5173

# JWT secret used for signing auth tokens.
JWT_SECRET=replace-with-a-long-random-secret

# Token expiry supported by jsonwebtoken, for example 7d or 12h.
JWT_EXPIRES_IN=7d

# App environment
NODE_ENV=development
